#!/bin/bash
# Project: SSH Guard - Brute Force Mitigation Tool
# Author:  Siona Larsen
# Date:    March 2026
#
# Description:
# This script monitors system authentication logs for failed login attempts.
# If an IP exceeds a defined threshold, it is dynamically added to an 
# nftables/iptables blocklist to prevent further attacks.
#######################################

#1. Global Functions

# Function: Centralized logging for both terminal (if verbose) and audit log
log_msg() {
    local TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
    # 1. Always append to the audit log for accountability
    if [[ -n "$AUDIT" ]]; then
        echo "[$TIMESTAMP] $1" >> "$AUDIT"
    fi
    # 2. Only print to screen if VERBOSE is 'y' or unset (default to talking)
    if [[ "$VERBOSE" != [Nn]* ]]; then
        echo "$1"
    fi
}

# Function: Critical errors that always print to screen and log
log_error() {
    local TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
    echo "ERROR: $1" >&2
    if [[ -n "$AUDIT" ]]; then
        echo "[$TIMESTAMP] ERROR: $1" >> "$AUDIT"
    fi
}

# Allows for users to customize the configuration file to match the file types they use
run_setup() {
	echo "---Setup---"
	read -p "Log to monitor: " INPUT_LOG
	read -p "Fail log destination: " INPUT_FAIL
	read -p "Threshold of failures: " INPUT_THRESHOLD
	read -p "Whitelisted IP file: " INPUT_WHITELIST
	read -p "Blocked IPs destination: " INPUT_AUDIT
	read -p "Enable detailed terminal output? (y/n): " INPUT_VERBOSE

cat << EOF > "$CONFIG"
LOG="$INPUT_LOG"
FAIL="$INPUT_FAIL"
THRESHOLD="$INPUT_THRESHOLD"
WHITELIST="$INPUT_WHITELIST"
AUDIT="$INPUT_AUDIT"
VERBOSE="$INPUT_VERBOSE"
EOF
	    echo "Configuration saved to $CONFIG."
	    source "$CONFIG"
}

#2. Configuration & Environment
CONFIG="../ssh_guard.conf"

if [[ -f "$CONFIG" ]]; then
	#The file exists and is loaded
	source "$CONFIG"
else
	#The file is missing and runs setup function
	echo "No configuration found. Starting first-time setup..."
	run_setup

fi

#3. Interactive Update Option
#To allow for automation, update response timesout after 5 seconds
read -t 5 -p "Would you like to review or update settings? (y/n): " UPDATE || UPDATE="n"
if [[ "$UPDATE" == [Yy]* ]]; then
    echo "Current Settings: LOG=$LOG, THRESHOLD=$THRESHOLD, VERBOSE=$VERBOSE"
    read -p "Update these now? (y/n): " CONFIRM
    if [[ "$CONFIRM" == [Yy]* ]]; then
        run_setup
    fi
fi

#4. Main Execution
log_msg "---Beginning SSH Guard Scan---"

# Verify files exist before running to prevent grep/awk crashes
if [[ ! -f "$LOG" ]]; then
    log_error "Source log not found at $LOG. Check your config."
    exit 1
fi

#Step 1: Filter log for failures
grep -iE "failed|invalid" "$LOG" >> $FAIL

#Step 2: Analyze failures and act
awk '{print $11}' $FAIL | sort | uniq -c | while read COUNT IP; do
    if [[ "$COUNT" -ge "$THRESHOLD" ]]; then

	# Security logic: Check Whitelist and Audit (already blocked)
    if grep -q "$IP" "$WHITELIST" 2>/dev/null; then
        log_msg "NOTICE: $IP is whitelisted. Skipping."
    elif grep -q "$IP" "$AUDIT" 2>/dev/null; then
        continue 
    else
        log_msg "ACTION: Blocking $IP ($COUNT failures detected)"
        # Future home of: nft add element inet filter blackhole { $IP }
        fi
    fi
done

log_msg "--- Scan Complete ---"
